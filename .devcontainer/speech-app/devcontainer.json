{
  "name": "speech-app-dev",
  "build": {
    "dockerfile": "../../speech-app/Dockerfile",
    "context": "../../speech-app"
  },
  "runArgs": [
    "--privileged",
    "--network=host",
    "--volume=/dev:/dev"
  ],
  "forwardPorts": [8000],
  "postCreateCommand": "cd speech-app && pip install -r requirements.txt"
}
